<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Scour.Controls.RadialGauge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="Root" Width="{x:Bind Diameter, Mode=OneWay}" Height="{x:Bind Diameter, Mode=OneWay}">
        <Ellipse x:Name="Track" Stroke="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                 StrokeThickness="{x:Bind RingThickness, Mode=OneWay}" Opacity="0.25" />
        <Path x:Name="ValueArc" Stroke="{x:Bind GaugeForeground, Mode=OneWay}"
              StrokeThickness="{x:Bind RingThickness, Mode=OneWay}" StrokeStartLineCap="Round"
              StrokeEndLineCap="Round" />
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
            <TextBlock x:Name="CenterValue" HorizontalAlignment="Center" FontSize="30" FontWeight="SemiBold" />
            <TextBlock x:Name="CenterCaption" HorizontalAlignment="Center" FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Grid>
</UserControl>
