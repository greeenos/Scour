<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Scour.Controls.UsageBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    SizeChanged="OnSizeChanged">

    <Border x:Name="Track" Height="6" CornerRadius="3"
            Background="{ThemeResource ControlStrongStrokeColorDefaultBrush}" Opacity="1"
            HorizontalAlignment="Stretch" VerticalAlignment="Center">
        <Border x:Name="Fill" Height="6" CornerRadius="3" HorizontalAlignment="Left"
                Background="{x:Bind BarBrush, Mode=OneWay}" Width="0" />
    </Border>
</UserControl>
