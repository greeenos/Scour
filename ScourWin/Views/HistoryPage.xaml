<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Scour.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Scour.ViewModels">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="History" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="A record of what was removed. Items sent to the Recycle Bin can be restored from there." />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,12">
            <Button Content="Refresh" Command="{x:Bind Vm.LoadCommand}" />
            <Button Content="Open Recycle Bin" Click="OnOpenRecycleBin" />
            <Button Content="Clear history" Command="{x:Bind Vm.ClearCommand}" />
        </StackPanel>

        <ListView Grid.Row="2" ItemsSource="{x:Bind Vm.Entries, Mode=OneWay}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:HistoryRow">
                    <Expander HorizontalAlignment="Stretch" Margin="0,4">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{x:Bind AppName}" />
                                    <TextBlock Text="{x:Bind Summary}" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{x:Bind When}" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </Expander.Header>
                        <TextBlock Text="{x:Bind Details}" FontFamily="Consolas" FontSize="12"
                                   TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                    </Expander>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="3" Margin="0,12,0,0" Text="{x:Bind Vm.StatusText, Mode=OneWay}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
    </Grid>
</Page>
