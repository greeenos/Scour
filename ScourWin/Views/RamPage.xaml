<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Scour.Views.RamPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="using:Scour.Controls">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16" MaxWidth="820" HorizontalAlignment="Stretch">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="24" />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <StackPanel>
                <TextBlock Text="RAM Cleaner" Style="{StaticResource PageTitle}" />
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="Frees memory by trimming process working sets. Run as administrator to also purge the system standby (cached) memory." />
            </StackPanel>

            <ProgressBar Style="{StaticResource LoadingBar}" IsIndeterminate="True"
                         Visibility="{x:Bind Vm.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

            <!-- Hero: gauge + stats -->
            <Border Style="{StaticResource HeroCard}">
                <Grid ColumnSpacing="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <c:RadialGauge x:Name="Gauge" Grid.Column="0" Diameter="170" RingThickness="16"
                                   Value="{x:Bind Vm.UsedPercent, Mode=OneWay}" Maximum="100"
                                   Caption="in use" GaugeForeground="{StaticResource PearAccentGradient}" />

                    <Grid Grid.Column="1" VerticalAlignment="Center" RowSpacing="14" ColumnSpacing="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="{x:Bind Vm.UsedText, Mode=OneWay}" Style="{StaticResource StatValue}" />
                            <TextBlock Text="In use" Style="{StaticResource StatCaption}" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="{x:Bind Vm.AvailableText, Mode=OneWay}" Style="{StaticResource StatValue}" />
                            <TextBlock Text="Available" Style="{StaticResource StatCaption}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock Text="{x:Bind Vm.TotalText, Mode=OneWay}" Style="{StaticResource StatValue}" />
                            <TextBlock Text="Total physical" Style="{StaticResource StatCaption}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                            <Button Content="Free memory" Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind Vm.CleanCommand}"
                                    IsEnabled="{x:Bind Vm.IsBusy, Mode=OneWay, Converter={StaticResource InverseBool}}" />
                            <Button Content="Refresh" Command="{x:Bind Vm.RefreshCommand}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Live memory graph -->
            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Memory usage over time" FontWeight="SemiBold" />
                    <c:Sparkline x:Name="History" Height="120" Maximum="100"
                                 LineBrush="{StaticResource PearAccentGradient}" />
                    <TextBlock Style="{StaticResource StatCaption}" Text="Updates every second." />
                </StackPanel>
            </Border>

            <TextBlock Text="{x:Bind Vm.StatusText, Mode=OneWay}" Style="{StaticResource PageSubtitle}" />
        </StackPanel>
    </ScrollViewer>
</Page>
