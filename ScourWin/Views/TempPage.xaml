<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Scour.Views.TempPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Scour.Models"
    xmlns:c="using:Scour.Controls">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Temp Files" Style="{StaticResource PageTitle}" />
            <TextBlock Style="{StaticResource PageSubtitle}"
                       Text="Clear Windows and per-user temporary files and caches. Some categories need administrator rights." />
        </StackPanel>

        <ProgressBar Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource LoadingBar}" IsIndeterminate="True"
                     Visibility="{x:Bind Vm.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12">
            <Button Content="Scan" Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind Vm.ScanCommand}"
                    IsEnabled="{x:Bind Vm.IsBusy, Mode=OneWay, Converter={StaticResource InverseBool}}" />
            <Button Content="Clean selected" Command="{x:Bind Vm.CleanCommand}"
                    IsEnabled="{x:Bind Vm.IsBusy, Mode=OneWay, Converter={StaticResource InverseBool}}" />
        </StackPanel>

        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="6">
            <ListView ItemsSource="{x:Bind Vm.Categories, Mode=OneWay}" SelectionMode="None">
                <ListView.ItemContainerTransitions>
                    <TransitionCollection>
                        <AddDeleteThemeTransition />
                        <ReorderThemeTransition />
                    </TransitionCollection>
                </ListView.ItemContainerTransitions>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:CleanupCategory">
                        <Grid Padding="6,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" MinWidth="32" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}" />
                                <TextBlock Text="{x:Bind Description}" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <c:UsageBar Grid.Column="2" VerticalAlignment="Center" Margin="4,0"
                                        Value="{x:Bind SizeValue, Mode=OneWay}" Maximum="{x:Bind GroupMaxValue, Mode=OneWay}"
                                        BarBrush="{StaticResource PearAccentGradient}" />
                            <TextBlock Grid.Column="3" Text="{x:Bind SizeDisplay, Mode=OneWay}" VerticalAlignment="Center"
                                       MinWidth="70" TextAlignment="Right"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <TextBlock Grid.Row="4" Margin="0,12,0,0" Text="{x:Bind Vm.StatusText, Mode=OneWay}"
                   Style="{StaticResource PageSubtitle}" />
    </Grid>
</Page>
