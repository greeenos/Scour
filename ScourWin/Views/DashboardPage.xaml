<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Scour.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="using:Scour.Controls">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="18" MaxWidth="980">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="24" />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <StackPanel>
                <TextBlock Text="Welcome to Scour" Style="{StaticResource PageTitle}" FontSize="28" />
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="Uninstall apps cleanly, reclaim disk space, and keep Windows tidy." />
            </StackPanel>

            <!-- Gauges -->
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource HeroCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Memory" FontWeight="SemiBold" />
                        <c:RadialGauge Diameter="150" RingThickness="14"
                                       Value="{x:Bind Vm.RamPercent, Mode=OneWay}" Maximum="100"
                                       Caption="{x:Bind Vm.RamCaption, Mode=OneWay}"
                                       GaugeForeground="{StaticResource PearAccentGradient}"
                                       HorizontalAlignment="Center" />
                        <TextBlock Text="{x:Bind Vm.RamDetail, Mode=OneWay}" Style="{StaticResource StatCaption}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource HeroCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{x:Bind Vm.DiskDrive, Mode=OneWay}" FontWeight="SemiBold" />
                        <c:RadialGauge Diameter="150" RingThickness="14"
                                       Value="{x:Bind Vm.DiskPercent, Mode=OneWay}" Maximum="100"
                                       Caption="used" GaugeForeground="{StaticResource PearWarmGradient}"
                                       HorizontalAlignment="Center" />
                        <TextBlock Text="{x:Bind Vm.DiskDetail, Mode=OneWay}" Style="{StaticResource StatCaption}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Stat tiles -->
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10" Background="{StaticResource PearAccentGradient}">
                            <FontIcon Glyph="&#xE71D;" Foreground="White" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Vm.AppCount, Mode=OneWay}" Style="{StaticResource StatValue}" />
                            <TextBlock Text="Installed applications" Style="{StaticResource StatCaption}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10" Background="{StaticResource PearWarmGradient}">
                            <FontIcon Glyph="&#xE74D;" Foreground="White" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Vm.Reclaimable, Mode=OneWay}" Style="{StaticResource StatValue}" />
                            <TextBlock Text="Reclaimable temp files" Style="{StaticResource StatCaption}" />
                        </StackPanel>
                        <ProgressRing Grid.Column="2" IsActive="{x:Bind Vm.IsScanningTemp, Mode=OneWay}" Width="20" Height="20" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Quick actions -->
            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Quick actions" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Click="GoApps" MinWidth="150">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" FontSize="16" />
                                <TextBlock Text="Uninstall an app" />
                            </StackPanel>
                        </Button>
                        <Button Click="GoTemp" MinWidth="150">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE894;" FontSize="16" />
                                <TextBlock Text="Clean temp files" />
                            </StackPanel>
                        </Button>
                        <Button Click="GoRam" MinWidth="150">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEEA0;" FontSize="16" />
                                <TextBlock Text="Free memory" />
                            </StackPanel>
                        </Button>
                        <Button Click="GoUpdater" MinWidth="150">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE777;" FontSize="16" />
                                <TextBlock Text="Update apps" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
