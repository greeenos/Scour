<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Scour.Views.ConsolePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Console" Style="{ThemeResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            <Button Content="Clear" HorizontalAlignment="Right" Click="OnClear" />
        </Grid>

        <ScrollViewer x:Name="Scroller" Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}"
                      Padding="12" CornerRadius="6">
            <ItemsControl x:Name="LinesControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
