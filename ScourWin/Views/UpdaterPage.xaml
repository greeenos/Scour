<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Scour.Views.UpdaterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Scour.Models">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="App Updater" Style="{StaticResource PageTitle}" />
            <TextBlock Style="{StaticResource PageSubtitle}"
                       Text="Updates installed apps via the Windows Package Manager (winget). Requires the 'App Installer' from the Microsoft Store." />
        </StackPanel>

        <ProgressBar Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource LoadingBar}" IsIndeterminate="True"
                     Visibility="{x:Bind Vm.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12">
            <Button Content="Check for updates" Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind Vm.CheckCommand}"
                    IsEnabled="{x:Bind Vm.IsBusy, Mode=OneWay, Converter={StaticResource InverseBool}}" />
            <Button Content="Update selected" Command="{x:Bind Vm.UpdateSelectedCommand}"
                    IsEnabled="{x:Bind Vm.IsBusy, Mode=OneWay, Converter={StaticResource InverseBool}}" />
            <Button Content="Select all" Command="{x:Bind Vm.SelectAllCommand}" />
            <Button Content="Deselect all" Command="{x:Bind Vm.DeselectAllCommand}" />
        </StackPanel>

        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="6">
            <ListView ItemsSource="{x:Bind Vm.Packages, Mode=OneWay}" SelectionMode="None">
                <ListView.ItemContainerTransitions>
                    <TransitionCollection>
                        <AddDeleteThemeTransition />
                    </TransitionCollection>
                </ListView.ItemContainerTransitions>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:UpdatablePackage">
                        <Grid Padding="6,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" MinWidth="32" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}" />
                                <TextBlock Text="{x:Bind Id}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="6" Padding="8,3"
                                    Background="{ThemeResource LayerFillColorAltBrush}">
                                <TextBlock FontSize="12">
                                    <Run Text="{x:Bind CurrentVersion}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /><Run Text="  →  " /><Run Text="{x:Bind AvailableVersion}" Foreground="{StaticResource PearAccentBrush}" />
                                </TextBlock>
                            </Border>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" MinWidth="80">
                                <ProgressRing IsActive="{x:Bind IsUpdating, Mode=OneWay}" Width="16" Height="16" />
                                <TextBlock Text="{x:Bind StatusText, Mode=OneWay}" Foreground="{StaticResource PearAccentBrush}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <TextBlock Grid.Row="4" Margin="0,12,0,0" Text="{x:Bind Vm.StatusText, Mode=OneWay}"
                   Style="{StaticResource PageSubtitle}" />
    </Grid>
</Page>
