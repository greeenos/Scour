<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Scour.Views.AppsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Scour.Models"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- App list -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <AutoSuggestBox Grid.Row="0" PlaceholderText="Search applications..."
                            QueryIcon="Find"
                            Text="{x:Bind Vm.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8" Spacing="8">
                <TextBlock Text="{x:Bind Vm.AppCountText, Mode=OneWay}" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ProgressRing IsActive="{x:Bind Vm.IsLoadingApps, Mode=OneWay}" Width="16" Height="16" />
                <Button Content="Refresh" Command="{x:Bind Vm.LoadAppsCommand}" />
            </StackPanel>

            <ListView Grid.Row="2"
                      ItemsSource="{x:Bind Vm.Apps, Mode=OneWay}"
                      SelectedItem="{x:Bind Vm.SelectedApp, Mode=TwoWay}"
                      SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:AppInfo">
                        <Grid Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE71D;" Margin="0,0,10,0"
                                      Foreground="{StaticResource PearAccentBrush}" />
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{x:Bind DisplayName}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Publisher}" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Detail / leftovers -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Visibility="{x:Bind Vm.SelectedApp, Mode=OneWay, Converter={StaticResource StringNotEmptyToVisibility}, FallbackValue=Collapsed}">
                <TextBlock Text="{x:Bind Vm.SelectedApp.DisplayName, Mode=OneWay}" Style="{StaticResource PageTitle}" />
                <TextBlock Margin="0,2,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="{x:Bind Vm.SelectedApp.Publisher, Mode=OneWay}" /><Run Text="  •  " /><Run Text="{x:Bind Vm.SelectedApp.Version, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Text="{x:Bind Vm.SelectedApp.InstallLocation, Mode=OneWay}" FontSize="11"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!-- Toolbar -->
            <Grid Grid.Row="1" Margin="0,12,0,8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Select all" Command="{x:Bind Vm.SelectAllCommand}" />
                    <Button Content="Deselect all" Command="{x:Bind Vm.DeselectAllCommand}" />
                    <ProgressRing IsActive="{x:Bind Vm.IsScanning, Mode=OneWay}" Width="18" Height="18" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="Selected: " /><Run Text="{x:Bind Vm.SelectedLeftoverSizeDisplay, Mode=OneWay}" />
                </TextBlock>
            </Grid>

            <!-- Leftover list -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="6">
            <Grid>
                <ListView ItemsSource="{x:Bind Vm.Leftovers, Mode=OneWay}"
                      SelectionMode="None" ScrollViewer.HorizontalScrollMode="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListView.ItemContainerTransitions>
                    <TransitionCollection>
                        <AddDeleteThemeTransition />
                    </TransitionCollection>
                </ListView.ItemContainerTransitions>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:FileItem">
                        <Grid Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" MinWidth="32" />
                            <FontIcon Grid.Column="1" Glyph="{x:Bind Kind, Converter={StaticResource KindToGlyph}}"
                                      Margin="0,0,10,0" FontSize="16"
                                      Foreground="{StaticResource PearAccentBrush}" />
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Path}" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Grid.Column="3" Text="{x:Bind SizeDisplay}" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                </ListView>

                <!-- Empty / scanning overlay -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10"
                            Visibility="{x:Bind Vm.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <ProgressRing IsActive="{x:Bind Vm.IsScanning, Mode=OneWay}" Width="36" Height="36" />
                    <TextBlock Text="Scanning for leftovers..." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>
            </Border>

            <!-- Footer / actions -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <TextBlock Text="{x:Bind Vm.StatusText, Mode=OneWay}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <CheckBox x:Name="RunUninstallerCheck" Content="Run app's uninstaller too" IsChecked="True"
                              VerticalAlignment="Center" />
                    <Button Content="Remove selected" Style="{ThemeResource AccentButtonStyle}"
                            Click="OnRemoveClick"
                            IsEnabled="{x:Bind Vm.IsRemoving, Mode=OneWay, Converter={StaticResource InverseBool}}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
