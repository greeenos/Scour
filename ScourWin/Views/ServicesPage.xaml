<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Scour.Views.ServicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Scour.Models">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Services" Style="{StaticResource PageTitle}" />
            <TextBlock Style="{StaticResource PageSubtitle}"
                       Text="Windows services left running by installed apps. Starting/stopping requires administrator rights." />
        </StackPanel>

        <ProgressBar Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource LoadingBar}" IsIndeterminate="True"
                     Visibility="{x:Bind Vm.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

        <Grid Grid.Row="2" Margin="0,12" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <AutoSuggestBox Grid.Column="0" PlaceholderText="Filter services..." QueryIcon="Find"
                            Text="{x:Bind Vm.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="1" Content="Refresh" Command="{x:Bind Vm.LoadCommand}" />
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="6">
            <ListView ItemsSource="{x:Bind Vm.Services, Mode=OneWay}" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ServiceItem">
                        <Grid Padding="6,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="9" Height="9" Margin="2,0,12,0" VerticalAlignment="Center"
                                     Fill="{x:Bind IsRunning, Mode=OneWay, Converter={StaticResource BoolToStatusBrush}}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind DisplayName}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Name}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{x:Bind Status, Mode=OneWay}" VerticalAlignment="Center" Margin="12,0"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Button Grid.Column="3" Content="{x:Bind ActionLabel, Mode=OneWay}"
                                    Click="OnToggle" MinWidth="72"
                                    IsEnabled="{x:Bind IsBusy, Mode=OneWay, Converter={StaticResource InverseBool}}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <TextBlock Text="{x:Bind Vm.StatusText, Mode=OneWay}" Style="{StaticResource PageSubtitle}" />
        </StackPanel>
    </Grid>
</Page>
